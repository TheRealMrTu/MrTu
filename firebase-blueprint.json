{
  "entities": {
    "Project": {
      "title": "Music Project",
      "description": "A saved music composition including sequencer patterns and settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the song" },
        "bpm": { "type": "integer", "description": "Tempo in BPM", "minimum": 40, "maximum": 300 },
        "volume": { "type": "integer", "description": "Master volume level in dB", "minimum": -60, "maximum": 10 },
        "grid": { 
          "type": "object", 
          "description": "Map of instrument IDs to 32-step boolean arrays",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "boolean" },
            "minItems": 32,
            "maxItems": 32
          }
        },
        "userId": { "type": "string", "description": "Firebase Auth UID of the owner" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "bpm", "volume", "grid", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Collection of music projects"
    }
  }
}
